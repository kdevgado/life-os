---
import "../../styles/globals.css";
import Header from "../layout/Header.astro";

const { title = "Life OS" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <script is:inline>
      try {
        const raw = localStorage.getItem("lifeos_theme") || "duna";
        const t = String(raw).trim().toLowerCase();
        document.documentElement.setAttribute("data-theme", t === "nebula" ? "nebula" : "duna");
      } catch {}
    </script>
  </head>

  <body>
    <div class="theme-hero-bg" aria-hidden="true">
      <div class="nebula-twinkle" aria-hidden="true"></div>
    </div>
    <main class="container">
      {title && (
        <Header title={title} />
      )}
      <slot />
    </main>

    <script type="module">
      import { applyThemeOnLoad } from "...";
      applyThemeOnLoad();
    </script>

    <script is:inline>
      (function () {
        try {
          const root = document.documentElement;

          // pick the actual scrolling element
          const scroller =
            document.querySelector("main") ||
            document.scrollingElement ||
            document.documentElement;

          const onScroll = () => {
            const y = scroller.scrollTop ?? window.scrollY ?? 0;
            if (y > 6) root.classList.add("nav-scrolled");
            else root.classList.remove("nav-scrolled");
          };

          // listen to BOTH, in case your app scrolls window sometimes and main other times
          window.addEventListener("scroll", onScroll, { passive: true });
          scroller.addEventListener?.("scroll", onScroll, { passive: true });

          onScroll();
        } catch {}
      })();
    </script>
  </body>
</html>