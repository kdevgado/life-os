---
import "../../styles/globals.css";
import Sidebar from "./Sidebar.astro";
import ImmersiveBackground from "./ImmersiveBackground";
import WidgetRail from "./WidgetRail";

const { title = "Life OS" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <script is:inline>
      try {
        const raw = localStorage.getItem("lifeos_theme") || "duna";
        const t = String(raw).trim().toLowerCase();
        document.documentElement.setAttribute("data-theme", t === "nebula" ? "nebula" : "duna");
      } catch {}
    </script>
  </head>

  <body class="iw-app">
    <ImmersiveBackground client:load />

    <div class="iw-shell">
      <Sidebar />

      <main class="iw-main" aria-label="Workspace">
        <header class="iw-topbar">
          <div class="iw-page-title">{title}</div>
        </header>

        <section class="iw-content">
          <slot />
        </section>
      </main>

      <WidgetRail client:load />
    </div>
  </body>
</html>