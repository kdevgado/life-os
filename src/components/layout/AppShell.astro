---
import "../../styles/globals.css";
import WorkspaceMode from "./WorkspaceMode";
import { IMAGE_WALLPAPERS } from "../../data/wallpapers";

const { title = "Life OS" } = Astro.props;
const startupImageWallpapers = IMAGE_WALLPAPERS.map((item) => item.src);
const isProductionBuild = import.meta.env.PROD;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="theme-color" content="#ffffff" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <script is:inline define:vars={{ isProductionBuild }}>
      if (isProductionBuild && "serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js").catch((error) => {
            console.warn("[PWA] service worker registration failed", error);
          });
        });
      }
    </script>

    <script is:inline>
      window.__lifeosDeferredPrompt = null;

      window.addEventListener("beforeinstallprompt", (e) => {
        console.log("[PWA] captured early in AppShell", e);
        e.preventDefault();
        window.__lifeosDeferredPrompt = e;
        window.dispatchEvent(new CustomEvent("lifeos:install-available"));
      });

      window.addEventListener("appinstalled", () => {
        console.log("[PWA] appinstalled fired");
        window.__lifeosDeferredPrompt = null;
        window.dispatchEvent(new CustomEvent("lifeos:installed"));
      });
    </script>

    <script is:inline>
      try {
        const savedTheme = localStorage.getItem("lifeos_theme");
        const systemTheme = window.matchMedia?.("(prefers-color-scheme: dark)")
          .matches
          ? "nebula"
          : "duna";
        const t = String(savedTheme || systemTheme).trim().toLowerCase();
        document.documentElement.setAttribute(
          "data-theme",
          t === "nebula" ? "nebula" : "duna",
        );
      } catch {}
    </script>

    <script is:inline define:vars={{ startupImageWallpapers }}>
      try {
        const savedWallpaper = localStorage.getItem("lifeos_wallpaper");
        const fallbackImages = startupImageWallpapers;
        const randomImage =
          fallbackImages[Math.floor(Math.random() * fallbackImages.length)] ||
          "/images/duna-sky.jpg";
        const startupWallpaper = savedWallpaper || randomImage;

        window.__lifeosStartupWallpaper = startupWallpaper;

        document.documentElement.style.setProperty(
          "--lifeos-startup-image",
          `url("${/\.(mp4|webm|ogg)$/i.test(startupWallpaper) ? randomImage : startupWallpaper}")`,
        );
      } catch {}
    </script>
  </head>

  <body class="iw-app">
    <!-- Wallpaper background layer (no hydration) -->
    <div class="iw-bg" aria-hidden="true">
      <div id="iw-bg-image" class="iw-bg__image"></div>
      <video
        id="iw-bg-video"
        class="iw-bg__video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"></video>
    </div>

    <script is:inline>
      (function () {
        try {
          const readWallpaperAudio = () => {
            try {
              const savedMuted = localStorage.getItem("lifeos_wallpaper_muted");
              const savedVolume = localStorage.getItem("lifeos_wallpaper_volume");
              const muted = savedMuted === null ? true : savedMuted === "true";
              const parsedVolume =
                savedVolume === null ? 0.5 : Number(savedVolume);
              const volume = Number.isFinite(parsedVolume)
                ? Math.max(0, Math.min(1, parsedVolume))
                : 0.5;

              return { muted, volume };
            } catch {
              return { muted: true, volume: 0.5 };
            }
          };

          const applyWallpaperAudio = (video) => {
            const { muted, volume } = readWallpaperAudio();
            video.defaultMuted = muted;
            video.muted = muted;
            video.volume = muted ? 0 : volume;
          };

          const syncVideoPlayback = (video, src) => {
            applyWallpaperAudio(video);

            if (video.getAttribute("src") !== src) {
              video.setAttribute("src", src);
              video.load();
            }

            const p = video.play();
            if (p && typeof p.catch === "function") p.catch(() => {});
          };

          const val =
            localStorage.getItem("lifeos_wallpaper") ||
            window.__lifeosStartupWallpaper ||
            "/images/duna-sky.jpg";
          const isVideo = /\.(mp4|webm|ogg)$/i.test(val);

          const img = document.getElementById("iw-bg-image");
          const vid = document.getElementById("iw-bg-video");

          if (!img || !vid) return;

          if (isVideo) {
            img.style.display = "none";
            vid.style.display = "block";
            syncVideoPlayback(vid, val);
          } else {
            vid.style.display = "none";
            vid.pause();
            vid.removeAttribute("src");
            vid.load();
            img.style.display = "block";
            img.style.backgroundImage = "url(" + val + ")";
          }

          // Update on picker changes (your picker dispatches this event)
          window.addEventListener("lifeos:wallpaper", () => {
            try {
              const next =
                localStorage.getItem("lifeos_wallpaper") ||
                "/images/duna-sky.jpg";
              const nextIsVideo = /\.(mp4|webm|ogg)$/i.test(next);

              if (nextIsVideo) {
                img.style.display = "none";
                vid.style.display = "block";
                syncVideoPlayback(vid, next);
              } else {
                vid.style.display = "none";
                vid.pause();
                vid.removeAttribute("src");
                vid.load();
                img.style.display = "block";
                img.style.backgroundImage = "url(" + next + ")";
              }
            } catch {}
          });

          window.addEventListener("lifeos:wallpaper-audio", () => {
            try {
              applyWallpaperAudio(vid);
              if (vid.style.display !== "none" && vid.getAttribute("src")) {
                const p = vid.play();
                if (p && typeof p.catch === "function") p.catch(() => {});
              }
            } catch {}
          });
        } catch {}
      })();
    </script>

    <div class="iw-shell">
      <WorkspaceMode client:load />
      <main class="lo-page-slot">
        <slot />
      </main>
    </div>
  </body>
</html>
