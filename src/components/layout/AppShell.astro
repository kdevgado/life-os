---
import "../../styles/globals.css";
import Header from "../layout/Header.astro";

const { title = "Life OS" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>

  <body>
    <main class="container">
      {title && (
        <Header title={title} />
      )}
      <slot />
    </main>
  </body>
</html>