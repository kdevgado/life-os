---
import AppShell from "../components/layout/AppShell.astro";
import DashboardTasksWidget from "../components/dashboard/DashboardTasksWidget";
import "../styles/globals.css";
---

<AppShell title="Life OS • Australian Life Planner">
  <DashboardTasksWidget client:load />
  <section class="hero">
    <div class="container">
      <h1>Life OS</h1>
      <p class="subtitle">
        Donvale IT Department Life Planner for tasks, goals and clarity.
      </p>

      <div class="cta-row">
        <a href="/planner" class="btn primary">Open Planner</a>
        <a href="/tasks" class="btn danger">Open Tasks</a>
        <a href="/settings" class="btn ghost">Settings</a>
      </div>
    </div>
  </section>

  <section class="features container">
    <div class="feature-card">
      <h3>💰 Budget Clarity</h3>
      <p>Track income, rent, transport and savings in one simple monthly view.</p>
    </div>

    <div class="feature-card">
      <h3>🏡 House Deposit Tracker</h3>
      <p>Model your path to a $450k-$500k home based on real savings.</p>
    </div>

    <div class="feature-card">
      <h3>📅 Pay Cycle Smart</h3>
      <p>Works for monthly, fortnightly or weekly pay cycles.</p>
    </div>

    <div class="feature-card">
      <h3>📊 Financial Summary</h3>
      <p>Instant leftover calculation and savings forecast.</p>
    </div>
  </section>
</AppShell>