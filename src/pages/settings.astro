---
import AppShell from "../components/layout/AppShell.astro";
---

<AppShell title="Settings • Life OS">
    <section class="settings">
        <h1>Settings</h1>

        <div class="settings-card">
            <div class="settings-row">
            <div class="settings-label">
                <strong>Theme</strong>
                <span>Switch between Duna (default) and Nebula.</span>
            </div>

            <select id="themeSelect" class="settings-select">
                <option value="duna">Duna (default)</option>
                <option value="nebula">Nebula</option>
            </select>
            </div>
        </div>

        <div class="settings-row">
            <div class="settings-label">
                <strong>Header solid-on-scroll</strong>
                <span>Header becomes slightly more solid when you scroll.</span>
            </div>

            <select id="navScrollSelect" class="settings-select">
                <option value="on">On</option>
                <option value="off">Off</option>
            </select>
            </div>
    </section>

  <script type="module">
    import { getTheme, setTheme } from "/src/scripts/theme.ts";

    const sel = document.getElementById("themeSelect");
    sel.value = getTheme();
    sel.addEventListener("change", (e) => setTheme(e.target.value));

    const NAV_KEY = "lifeos_nav_scroll";
    const navSel = document.getElementById("navScrollSelect");

    navSel.value = localStorage.getItem(NAV_KEY) || "on";

    navSel.addEventListener("change", (e) => {
    localStorage.setItem(NAV_KEY, e.target.value);
    // instant effect
    if (e.target.value === "off") document.documentElement.classList.remove("nav-scrolled");
    });
  </script>
</AppShell>